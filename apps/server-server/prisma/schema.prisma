datasource db {
  provider = "postgresql"
  url      = env("DB_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  annotations   Annotation?
  collaborators Collaborator[]
  createdAt     DateTime       @default(now())
  firstName     String?
  id            String         @id @default(cuid())
  isValid       Boolean?
  lastName      String?
  password      String
  projects      Project[]
  roles         String?
  updatedAt     DateTime       @updatedAt
  userRole      String?
  username      String         @unique
}

model AppConfig {
  createdAt DateTime @default(now())
  id        String   @id @default(cuid())
  key       String?  @unique
  updatedAt DateTime @updatedAt
  value     String?
}

model Aimodel {
  annotations Annotation[]
  createdAt   DateTime     @default(now())
  id          String       @id @default(cuid())
  modelType   String
  name        String
  updatedAt   DateTime     @updatedAt
}

model Project {
  collaborators Collaborator[]
  createdAt     DateTime       @default(now())
  description   String?
  id            String         @id @default(cuid())
  images        Image[]
  title         String
  tool          String?
  updatedAt     DateTime       @updatedAt
  user          User?          @relation(fields: [userId], references: [id])
  userId        String?
}

model Image {
  annotations Annotation[]
  createdAt   DateTime     @default(now())
  id          String       @id @default(cuid())
  name        String
  project     Project      @relation(fields: [projectId], references: [id])
  projectId   String
  updatedAt   DateTime     @updatedAt
  url         String?
}

model Annotation {
  aiModel       Aimodel[]
  createdAt     DateTime  @default(now())
  id            String    @id @default(cuid())
  image         Image     @relation(fields: [imageId], references: [id])
  imageId       String
  result        String?
  updatedAt     DateTime  @updatedAt
  url           String?
  validatedBy   User?     @relation(fields: [validatedById], references: [id])
  validatedById String?   @unique
}

model Collaborator {
  createdAt DateTime @default(now())
  id        String   @id @default(cuid())
  project   Project  @relation(fields: [projectId], references: [id])
  projectId String
  updatedAt DateTime @updatedAt
  user      User[]
}

model AuthModel {
  createdAt DateTime @default(now())
  id        String   @id @default(cuid())
  updatedAt DateTime @updatedAt
}
